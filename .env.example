MODEL_NAME=Qwen/Qwen2.5-Coder-1.5B-Instruct
DEVICE=
HUGGINGFACE_TOKEN=

NUM_EPISODES=20
MAX_STEPS=10
GAMMA=0.99
PRINT_EVERY=5

PROBLEMS_FILE=data/problems.json
TRAJECTORIES_FILE=trajectories.jsonl
LOG_FILE=training_log.csv
